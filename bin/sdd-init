#!/usr/bin/env bash
set -euo pipefail

# Initialize Single-Project SDD layout inside an existing directory.
# Usage: bin/sdd-init [<project-dir>] [--path|-p <dir>] [--stack "Python/FastAPI"] [--domain "web"] [--year 2026]

TARGET_DIR="$(pwd)"
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
STACK=""
DOMAIN=""
YEAR="$(date +%Y)"

while [[ $# -gt 0 ]]; do
  case "$1" in
    --path|-p) TARGET_DIR="$2"; shift 2;;
    --stack) STACK="$2"; shift 2;;
    --domain) DOMAIN="$2"; shift 2;;
    --year) YEAR="$2"; shift 2;;
    --*) echo "Unknown option: $1" >&2; exit 1;;
    *) TARGET_DIR="$1"; shift;;
  esac
done

mkdir -p \
  "$TARGET_DIR/.sdd/prompts" \
  "$TARGET_DIR/.sdd/backlog/open" \
  "$TARGET_DIR/.sdd/backlog/closed" \
  "$TARGET_DIR/.sdd/context" \
  "$TARGET_DIR/.sdd/researches" \
  "$TARGET_DIR/.sdd/researches/_templates"

PROJECT_NAME="$(basename "$TARGET_DIR")"

cat > "$TARGET_DIR/.sdd/config.json" <<JSON
{
  "project_name": "$PROJECT_NAME",
  "tech_stack": "$STACK",
  "domain": "$DOMAIN",
  "year": "$YEAR"
}
JSON

if [[ ! -f "$TARGET_DIR/.sdd/project.md" ]]; then
cat > "$TARGET_DIR/.sdd/project.md" <<MD
# Project Description

Briefly describe the task/project: goals, constraints, audience. 3–5 sentences is enough to start.

## Core
- Primary goal: ...
- Users/personas: ...
- Key constraints (tech, org, compliance): ...

## Definition of Done
List 5–10 concrete conditions that must be true when the project is “Done” (functional and non‑functional).
- Functional outcomes (what users can do): ...
- Quality attributes (performance, reliability, security, UX): ...
- Process constraints (tests, documentation, release criteria): ...

## Non‑functional Requirements (optional)
- Performance / latency / throughput: ...
- Availability / reliability / SLOs: ...
- Security / compliance: ...
- Observability / operations: ...
- AI / agent workflow constraints: ...
- Cost / quota limits: ...
MD
fi

if [[ ! -f "$TARGET_DIR/.sdd/issues.md" ]]; then
cat > "$TARGET_DIR/.sdd/issues.md" <<MD
# SDD Issues

Record spec conflicts, blocked decisions, and missing inputs here.
MD
fi

if [[ ! -f "$TARGET_DIR/.sdd/researches/README.md" ]]; then
  cp "$REPO_ROOT/templates/researches_index_template.md" "$TARGET_DIR/.sdd/researches/README.md"
fi

for research_template in \
  researches_index_template.md \
  research_probe_template.md \
  research_run_manifest_template.md \
  research_closeout_template.md
do
  if [[ ! -f "$TARGET_DIR/.sdd/researches/_templates/$research_template" ]]; then
    cp "$REPO_ROOT/templates/$research_template" "$TARGET_DIR/.sdd/researches/_templates/$research_template"
  fi
done

echo "✅ SDD initialized in $TARGET_DIR (.sdd/prompts + .sdd/backlog/ + .sdd/context/ + .sdd/researches/)"
echo ""
echo "📋 Next steps:"
echo "1. Edit .sdd/project.md (describe your project)"
echo "2. Run: python bin/sdd-prompts \"$TARGET_DIR\""
echo "3. Follow the agent-first flow:"
echo "   → Step 1: Research (01_research.prompt.md → .sdd/best_practices.md)"
echo "   → Step 2: Architect (02_architect.prompt.md → .sdd/architect.md with <tickets> appendix)"
echo "   → Step 3: Sync tickets (python bin/sdd-backlog sync \"$TARGET_DIR\")"
echo "   → Step 4: Agent (03_agent.prompt.md → implement from .sdd/backlog/open/)"
echo "   → Step 5: Create research packs in .sdd/researches/ when a decision depends on measurement"
echo "   → Step 6: Janitor/Status (python bin/sdd-backlog janitor \"$TARGET_DIR\" && python bin/sdd-status \"$TARGET_DIR\")"

# After initialization, check what's been completed
if [[ -f "$TARGET_DIR/.sdd/best_practices.md" ]]; then
  echo "   ✅ Research completed"
else
  echo "   ⏳ Research pending"
fi

if [[ -f "$TARGET_DIR/.sdd/architect.md" ]]; then
  echo "   ✅ Architecture completed"
else
  echo "   ⏳ Architecture pending"
fi

OPEN_TICKETS=$(find "$TARGET_DIR/.sdd/backlog/open" -name "*.md" 2>/dev/null | wc -l | tr -d ' ')
CLOSED_TICKETS=$(find "$TARGET_DIR/.sdd/backlog/closed" -name "*.md" 2>/dev/null | wc -l | tr -d ' ')
if [[ $OPEN_TICKETS -gt 0 || $CLOSED_TICKETS -gt 0 ]]; then
  echo "   📝 Tickets: $CLOSED_TICKETS closed, $OPEN_TICKETS open"
fi
